#!/usr/bin/env bash
set -euo pipefail

PERSONAL_EMAIL_RE='[A-Za-z0-9._%+-]+@(gmail|outlook|hotmail|yahoo|icloud|me|live|aol)\.[a-z]{2,}'

# 1. Author identity check
# The staged-content PII scan below cannot see git metadata, so a
# personal-domain author email can still leak into commit history
# even when file contents are clean. Block it here.
AUTHOR_EMAIL=$(git var GIT_AUTHOR_IDENT | sed -n 's/.*<\([^>]*\)>.*/\1/p')
if printf '%s' "$AUTHOR_EMAIL" | grep -qE "$PERSONAL_EMAIL_RE"; then
  echo "ERROR: git author email '$AUTHOR_EMAIL' uses a personal domain." >&2
  echo "Switch to a GitHub noreply alias before committing:" >&2
  echo "  git config user.email '<numeric-id>+<login>@users.noreply.github.com'" >&2
  exit 1
fi

# 2. Secret scan via gitleaks
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "ERROR: gitleaks not installed. Install from https://github.com/gitleaks/gitleaks" >&2
  exit 1
fi

echo "Running gitleaks..."
gitleaks protect --staged --redact --config .gitleaks.toml

# 3. PII pattern scan
# Catches user-home directory references and personal-domain email
# addresses that often leak into committed content. Patterns are
# deliberately generic so the hook itself contains no specific PII.
echo "Running PII pattern check..."

PII_PATTERNS=(
  '[/\\]Users[/\\][A-Za-z0-9._-]+[/\\]'
  '[/\\]home[/\\][A-Za-z0-9._-]+[/\\]'
  "$PERSONAL_EMAIL_RE"
)

STAGED=$(git diff --cached --name-only --diff-filter=AM)
if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=0
while IFS= read -r file; do
  [ -z "$file" ] && continue
  for pattern in "${PII_PATTERNS[@]}"; do
    matches=$(git show ":$file" 2>/dev/null | grep -nE "$pattern" || true)
    if [ -n "$matches" ]; then
      if [ "$FOUND" -eq 0 ]; then
        echo "" >&2
        echo "PII patterns detected in staged content:" >&2
        FOUND=1
      fi
      echo "  $file" >&2
      printf '%s\n' "$matches" | head -3 | sed 's/^/    /' >&2
    fi
  done
done <<< "$STAGED"

if [ "$FOUND" -ne 0 ]; then
  echo "" >&2
  echo "Scrub the matches and re-stage. To adjust patterns, edit .githooks/pre-commit." >&2
  exit 1
fi

echo "No PII patterns detected."

# Configure only the clients you actually run. Each client requires all
# of its env vars to be set; the MCP server registers tools for a
# client only when its full config is present.

# SABnzbd (usenet)
# Default port: 8080
SABNZBD_URL=http://localhost:8080
SABNZBD_API_KEY=

# qBittorrent (torrents)
# Default WebUI port: 8080 (commonly remapped if SABnzbd is also 8080)
QBITTORRENT_URL=http://localhost:8081
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=
